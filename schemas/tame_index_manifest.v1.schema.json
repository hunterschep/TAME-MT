{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hunterschep/TAME-MT/schemas/tame_index_manifest.v1.schema.json",
  "title": "TAME-MT index manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "tame_version",
    "num_train",
    "has_target",
    "config",
    "normalization",
    "similarity",
    "index",
    "source_backend",
    "target_backend",
    "storage",
    "hashes",
    "privacy"
  ],
  "properties": {
    "format": {
      "const": "tameidx"
    },
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "tame_version": {
      "type": "string",
      "minLength": 1
    },
    "num_train": {
      "type": "integer",
      "minimum": 1
    },
    "has_target": {
      "type": "boolean"
    },
    "config": {
      "type": "object"
    },
    "normalization": {
      "type": "object"
    },
    "similarity": {
      "type": "object",
      "required": ["type", "ngram_orders"],
      "properties": {
        "type": {
          "type": "string"
        },
        "ngram_orders": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "index": {
      "type": "object"
    },
    "source_backend": {
      "$ref": "#/$defs/backend"
    },
    "target_backend": {
      "anyOf": [
        {
          "$ref": "#/$defs/backend"
        },
        {
          "type": "null"
        }
      ]
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container",
        "compression",
        "compresslevel",
        "native_index_schema_version",
        "source_index_bytes",
        "target_index_bytes",
        "exact_pair_keys_bytes"
      ],
      "properties": {
        "container": {
          "const": "zip"
        },
        "compression": {
          "type": "string"
        },
        "compresslevel": {
          "type": "integer"
        },
        "native_index_schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "source_index_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "target_index_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "exact_pair_keys_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "hashes": {
      "type": "object",
      "required": ["train_src_sha256", "train_src_normalized_sha256", "source_index_sha256"],
      "properties": {
        "train_src_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "train_src_normalized_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "train_tgt_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "train_tgt_normalized_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_index_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "target_index_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "exact_pair_keys_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stores_raw_training_text",
        "stores_normalized_exact_match_keys",
        "stores_normalized_pair_keys"
      ],
      "properties": {
        "stores_raw_training_text": {
          "type": "boolean"
        },
        "stores_normalized_exact_match_keys": {
          "type": "boolean"
        },
        "stores_normalized_pair_keys": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "backend": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "native", "exact", "requested_mode", "resolved_mode"],
      "properties": {
        "name": {
          "type": "string"
        },
        "native": {
          "type": "boolean"
        },
        "exact": {
          "type": "boolean"
        },
        "requested_mode": {
          "type": "string"
        },
        "resolved_mode": {
          "type": "string"
        }
      }
    }
  }
}
